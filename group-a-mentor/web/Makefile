# Commandes essentielles du frontend.

.PHONY: install dev build start lint help

help:
	@echo "Commandes disponibles :"
	@echo "  make install    - installe les dépendances npm"
	@echo "  make dev        - démarre Next.js dev server (port 3000)"
	@echo "  make build      - build production"
	@echo "  make start      - démarre le build de production"
	@echo "  make lint       - typecheck TypeScript"

install:
	npm install

dev:
	npm run dev

build:
	npm run build

start:
	npm run start

lint:
	npm run lint
