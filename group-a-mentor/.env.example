# ═══════════════════════════════════════════════════════════════════
# Groupe A — Candidature mentor + annuaire mentors + propositions classes
# Credentials Supabase branche groupe-a + OpenRouter dédié ($5 budget)
# ═══════════════════════════════════════════════════════════════════

# ─── Identité du service ─────────────────────────────────────────
SERVICE_NAME=group-a-mentor-api
BUILD_SHA=dev
BUILD_DATE=2026-05-11
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Base de données ─────────────────────────────────────────────
# Postgres local lancé via `docker compose up -d` (cf. docker-compose.yml)
# Supabase est utilisé pour l'Auth uniquement (cf. section Supabase ci-dessous).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# ─── Supabase ────────────────────────────────────────────────────
SUPABASE_URL=https://REPLACE_WITH_SUPABASE_BRANCH_URL.supabase.co
SUPABASE_ANON_KEY=sb_publishable_REPLACE_WITH_GROUP_KEY
SUPABASE_JWKS_URL=

# Service role key (privée — pour seeding admin). À fournir par Lorenzo.
SUPABASE_SERVICE_ROLE_KEY=

# ─── OpenRouter (LLM) ────────────────────────────────────────────
# Clé dédiée Groupe A — budget cap $5
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_GROUP_OPENROUTER_KEY
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-haiku

# ═══════════════════════════════════════════════════════════════════
# FRONTEND Next.js (les NEXT_PUBLIC_* sont exposées au browser)
# ═══════════════════════════════════════════════════════════════════

# URL du backend FastAPI du Groupe A (local pendant hackathon)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase frontend (mêmes valeurs que ci-dessus mais préfixées NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_WITH_SUPABASE_BRANCH_URL.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REPLACE_WITH_GROUP_KEY
