# Copier en .env.local (Next.js charge automatiquement)
# Le fichier .env.local est gitignored — ne jamais le commiter.

# ─── Backend API (le backend FastAPI de ton groupe) ──────────────
# Pendant le hackathon : ton backend tourne en local sur :8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# MIGRATION HINT (post-hackathon) :
#   En prod Hello Mira → https://api.hlmr.io (edge-gateway upstream)

# ─── Supabase ────────────────────────────────────────────────────
# Projet Supabase test fourni par Lorenzo (1 projet par groupe pour isolation)
# Projet Supabase test partagé entre les 4 groupes du hackathon Mira Learn
# (un seul projet pour tous, isolation logique par scopes Supabase RLS)
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_WITH_SUPABASE_MAIN_URL.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REPLACE_WITH_MAIN_ANON_KEY

# MIGRATION HINT :
#   En prod Hello Mira → NEXT_PUBLIC_SUPABASE_URL=https://auth.hlmr.io (custom domain)
#   Et JWT signing keys propres au projet prod.

# NOTE — Publishable key vs Anon key :
#   Supabase a renommé "anon key" → "publishable key" en 2025. Les 2 noms sont
#   interchangeables côté SDK (`@supabase/supabase-js` les accepte tous les deux).
#   On garde `NEXT_PUBLIC_SUPABASE_ANON_KEY` pour cohérence avec book-web (qui n'a
#   pas encore migré le naming).
