# Copier ce fichier en .env et renseigner les valeurs réelles.
# Le fichier .env est gitignored — ne jamais le commiter.

# ─── Identité du service ─────────────────────────────────────────
SERVICE_NAME=hackathon-group-X-api
BUILD_SHA=dev
BUILD_DATE=2026-05-11
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Base de données ─────────────────────────────────────────────
# Projet Supabase test partagé hackathon : REPLACE_WITH_SUPABASE_MAIN_REF
# Récupérer le DB password sur Settings → Database → Connection string et remplacer ci-dessous.
DATABASE_URL=postgresql+asyncpg://postgres:REPLACE_WITH_DB_PASSWORD@db.REPLACE_WITH_SUPABASE_MAIN_URL.supabase.co:5432/postgres

# ─── Supabase ────────────────────────────────────────────────────
# Projet partagé entre les 4 groupes hackathon Mira Learn
SUPABASE_URL=https://REPLACE_WITH_SUPABASE_MAIN_URL.supabase.co
SUPABASE_ANON_KEY=sb_publishable_REPLACE_WITH_MAIN_ANON_KEY
# Auto-dérivé depuis SUPABASE_URL si vide : https://REPLACE_WITH_SUPABASE_MAIN_URL.supabase.co/auth/v1/jwks
SUPABASE_JWKS_URL=

# Secret key (service_role — privée, pour admin operations comme seeding).
# À fournir par Lorenzo si besoin. NE PAS COMMITTER une fois remplie.
SUPABASE_SERVICE_ROLE_KEY=

# ─── OpenRouter (LLM) ────────────────────────────────────────────
# Clé partagée entre les 4 groupes pendant le hackathon, fournie par Lorenzo.
# Budget cap à $50 sur OpenRouter dashboard.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-haiku
