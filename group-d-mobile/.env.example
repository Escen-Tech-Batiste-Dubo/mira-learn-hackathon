# ═══════════════════════════════════════════════════════════════════
# Groupe D — Mobile Flutter : suivi class + notes IA + QCM + communauté
# Credentials Supabase branche groupe-d + OpenRouter dédié ($5 budget)
# ═══════════════════════════════════════════════════════════════════

# ─── Identité du service ─────────────────────────────────────────
SERVICE_NAME=group-d-mobile-api
BUILD_SHA=dev
BUILD_DATE=2026-05-11
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Base de données ─────────────────────────────────────────────
# Postgres local lancé via `docker compose up -d` (cf. docker-compose.yml).
# Supabase est utilisé pour l'Auth uniquement.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# ─── Supabase ────────────────────────────────────────────────────
SUPABASE_URL=https://REPLACE_WITH_SUPABASE_BRANCH_URL.supabase.co
SUPABASE_ANON_KEY=sb_publishable_REPLACE_WITH_GROUP_KEY
SUPABASE_JWKS_URL=

SUPABASE_SERVICE_ROLE_KEY=

# ─── OpenRouter (LLM) ────────────────────────────────────────────
# Clé dédiée Groupe D — budget cap $5
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_GROUP_OPENROUTER_KEY
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-haiku

# ═══════════════════════════════════════════════════════════════════
# MOBILE Flutter (variables exposées via --dart-define ou .env package)
# Format Dart : utiliser flutter_dotenv ou String.fromEnvironment
# ═══════════════════════════════════════════════════════════════════

# URL du backend FastAPI du Groupe D (local pendant hackathon)
MOBILE_API_URL=http://localhost:8000

# Pour iOS Simulator : http://localhost:8000 fonctionne
# Pour Android Emulator : http://10.0.2.2:8000 (10.0.2.2 = localhost de l'hôte)

# Supabase mobile
MOBILE_SUPABASE_URL=https://REPLACE_WITH_SUPABASE_BRANCH_URL.supabase.co
MOBILE_SUPABASE_ANON_KEY=sb_publishable_REPLACE_WITH_GROUP_KEY
